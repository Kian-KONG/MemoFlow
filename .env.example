# === MemoFlow 本地部署配置 ===

# App
MEMOFLOW_APP_NAME=MemoFlow
MEMOFLOW_ENV=development
MEMOFLOW_HOST=127.0.0.1
MEMOFLOW_PORT=8000
MEMOFLOW_SECRET_KEY=change-me-in-production

# 数据目录（音频文件、SQLite、LanceDB 均存放于此，默认放在项目根目录 ./data）
MEMOFLOW_DATA_DIR=./data
MEMOFLOW_DATABASE_URL=sqlite+aiosqlite:///./data/memoflow.db
MEMOFLOW_LANCEDB_DIR=./data/lancedb
MEMOFLOW_AUDIO_DIR=./data/audio

# --- VibeVoice ASR（本地权重，需先运行 ./scripts/download_vibevoice_asr.sh） ---
# 下载脚本会将 microsoft/VibeVoice-ASR-HF（Transformers 兼容）保存到下方路径
# 需安装: pip install -U "huggingface_hub[cli]"  然后运行 ./scripts/download_vibevoice_asr.sh
# 脚本使用 hf-mirror + HF_HUB_DISABLE_XET=1，避免大文件跳转海外 CDN
MEMOFLOW_ASR_MODEL_PATH=./models/VibeVoice-ASR
MEMOFLOW_ASR_DEVICE=auto           # auto | cpu | mps | cuda

# --- Bosch AIGC 网关（推荐：一个 Key 覆盖 LLM / Embedding / Rerank） ---
# 配置后无需再单独设置下方 MEMOFLOW_DEEPSEEK_* / OPENAI_* / RERANK_* 密钥
BOSCH_AIGC_API_KEY=
LLM_API_URL=https://aigc.bosch.com.cn/llmservice/api/v1/chat/completions
# LLM_MODEL=deepseek-v4-pro              # 可选，默认 deepseek-v4-pro
EMBEDDING_API_URL=https://aigc.bosch.com.cn/llmservice/api/v2/embeddings
EMBEDDING_MODEL=text-embedding-v3
RERANKER_API_URL=https://aigc.bosch.com.cn/llmservice/api/v1/rerank
RERANKER_MODEL=qwen3-rerank

# --- DeepSeek LLM（云端 API，Bosch 未配置时使用） ---
MEMOFLOW_DEEPSEEK_API_KEY=
MEMOFLOW_DEEPSEEK_BASE_URL=https://api.deepseek.com
MEMOFLOW_DEEPSEEK_MODEL=deepseek-v4-pro
MEMOFLOW_LLM_MAX_TOKENS=4096
MEMOFLOW_LLM_TEMPERATURE=0.3

# --- OpenAI Embedding（云端 API） ---
MEMOFLOW_OPENAI_API_KEY=
MEMOFLOW_OPENAI_BASE_URL=https://api.openai.com/v1
MEMOFLOW_EMBEDDING_MODEL=text-embedding-3-small
# MEMOFLOW_EMBEDDING_DIMENSIONS=          # 可选，留空则使用模型默认维度

# --- Qwen3 Reranker（DashScope 兼容 API） ---
MEMOFLOW_RERANK_API_KEY=
MEMOFLOW_RERANK_BASE_URL=https://dashscope.aliyuncs.com/compatible-api/v1
MEMOFLOW_RERANK_MODEL=qwen3-rerank
MEMOFLOW_RERANK_TOP_N=5
