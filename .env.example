# === MemoFlow 本地部署配置 ===

# App
MEMOFLOW_APP_NAME=MemoFlow
MEMOFLOW_ENV=development
MEMOFLOW_HOST=127.0.0.1
MEMOFLOW_PORT=8000
MEMOFLOW_SECRET_KEY=change-me-in-production

# 数据目录（音频文件、SQLite、LanceDB 均存放于此，默认放在项目根目录 ./data）
MEMOFLOW_DATA_DIR=./data
MEMOFLOW_DATABASE_URL=sqlite+aiosqlite:///./data/memoflow.db
MEMOFLOW_LANCEDB_DIR=./data/lancedb
MEMOFLOW_AUDIO_DIR=./data/audio

# --- ASR: SenseVoice (FunASR) ---
MEMOFLOW_ASR_MODEL=iic/SenseVoiceSmall
MEMOFLOW_ASR_DEVICE=cpu           # cpu | mps | cuda

# --- 说话人识别: pyannote ---
MEMOFLOW_DIARIZATION_MODEL=pyannote/speaker-diarization-3.1
MEMOFLOW_HF_TOKEN=                # HuggingFace access token（pyannote 模型需要）

# --- LLM: Qwen3-14B (MLX) ---
MEMOFLOW_LLM_MODEL_PATH=mlx-community/Qwen3-14B-4bit
MEMOFLOW_LLM_MAX_TOKENS=2048
MEMOFLOW_LLM_TEMPERATURE=0.3

# --- Embedding（知识库检索） ---
MEMOFLOW_EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
MEMOFLOW_EMBEDDING_DEVICE=cpu
